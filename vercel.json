{
  "functions": {
    "app/api/**/*.js": {
      "maxDuration": 10
    }
  },
  "buildCommand": "pnpm prisma generate && pnpm next build",
  "installCommand": "pnpm install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/tracking-notifications",
      "schedule": "0 9 * * *"
    }
  ]
}
